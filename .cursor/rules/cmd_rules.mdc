## 📡 Git 指令優化與管理

### Git 進程檢查
```powershell
# git-manager.ps1 - Git 進程管理工具
function Get-GitProcesses {
    Write-Host "🔍 檢查 Git 相關進程..." -ForegroundColor Cyan
    
    $gitProcesses = @()
    $gitProcesses += Get-Process -Name "git" -ErrorAction SilentlyContinue
    $gitProcesses += Get-Process -Name "git-*" -ErrorAction SilentlyContinue
    
    if ($gitProcesses) {
        Write-Host "📊 發現 $($gitProcesses.Count) 個 Git 進程:" -ForegroundColor Yellow
        
        foreach ($proc in $gitProcesses) {
            $runtime = (Get-Date) - $proc.StartTime
            Write-Host "  🟡 $($proc.ProcessName) PID: $($proc.Id)" -ForegroundColor Yellow
            Write-Host "     ⏰ 運行時間: $($runtime.ToString('hh\:mm\:ss'))" -ForegroundColor Gray
        }
    } else {
        Write-Host "✅ 無 Git 進程運行" -ForegroundColor Green
    }
}

function Clear-GitLocks {
    Write-Host "🔐 清理 Git 鎖定文件..." -ForegroundColor Cyan
    
    $gitDir = ".git"
    if (Test-Path $gitDir) {
        $lockFiles = @(
            "$gitDir/index.lock",
            "$gitDir/HEAD.lock",
            "$gitDir/config.lock",
            "$gitDir/refs/heads/*.lock"
        )
        
        $removedCount = 0
        foreach ($lockPattern in $lockFiles) {
            $locks = Get-ChildItem $lockPattern -ErrorAction SilentlyContinue
            foreach ($lock in $locks) {
                Remove-Item $lock.FullName -Force
                Write-Host "🗑️ 已移除: $($lock.Name)" -ForegroundColor Red
                $removedCount++
            }
        }
        
        if ($removedCount -eq 0) {
            Write-Host "✅ 無 Git 鎖定文件需要清理" -ForegroundColor Green
        } else {
            Write-Host "✅ 清理了 $removedCount 個 Git 鎖定文件" -ForegroundColor Green
        }
    } else {
        Write-Host "⚠️ 當前目錄不是 Git 倉庫" -ForegroundColor Yellow
    }
}
```

### Git 操作安全檢查
```powershell
function Test-GitSafety {
    Write-Host "🛡️ Git 操作安全檢查..." -ForegroundColor Cyan
    
    # 檢查是否有未提交的變更
    $status = git status --porcelain 2>$null
    if ($status) {
        Write-Host "⚠️ 發現未提交的變更:" -ForegroundColor Yellow
        git status --short
        Write-Host "💡 建議先提交或暫存變更" -ForegroundColor Blue
        return $false
    }
    
    # 檢查是否在正確的分支
    $currentBranch = git rev-parse --abbrev-ref HEAD 2>$null
    if ($currentBranch -ne "main") {
        Write-Host "📍 當前分支: $currentBranch" -ForegroundColor Yellow
        $choice = Read-Host "是否切換到 main 分支? (Y/N)"
        if ($choice -eq 'Y' -or $choice -eq 'y') {
            git checkout main
        }
    }
    
    Write-Host "✅ Git 安全檢查通過" -ForegroundColor Green
    return $true
}
```

