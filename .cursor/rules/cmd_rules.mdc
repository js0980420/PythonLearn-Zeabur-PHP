## 📊 系統監控與報告

### 自動監控腳本
```powershell
# system-monitor.ps1 - 系統監控工具
function Get-SystemStatus {
    Write-Host "📊 系統狀態報告" -ForegroundColor Cyan
    Write-Host "=================" -ForegroundColor Cyan
    
    # CPU 使用率
    $cpu = Get-WmiObject Win32_Processor | Measure-Object -Property LoadPercentage -Average
    Write-Host "🖥️ CPU 使用率: $([math]::Round($cpu.Average, 1))%" -ForegroundColor Green
    
    # 記憶體使用率
    $memory = Get-WmiObject Win32_OperatingSystem
    $memoryUsage = [math]::Round((($memory.TotalVisibleMemorySize - $memory.FreePhysicalMemory) / $memory.TotalVisibleMemorySize) * 100, 1)
    Write-Host "💾 記憶體使用率: $memoryUsage%" -ForegroundColor Green
    
    # 磁碟空間
    $disk = Get-WmiObject Win32_LogicalDisk -Filter "DeviceID='C:'"
    $diskUsage = [math]::Round((($disk.Size - $disk.FreeSpace) / $disk.Size) * 100, 1)
    Write-Host "💿 磁碟使用率: $diskUsage%" -ForegroundColor Green
    
    # Node.js 進程數
    $nodeCount = (Get-Process -Name "node" -ErrorAction SilentlyContinue).Count
    Write-Host "🟢 Node.js 進程數: $nodeCount" -ForegroundColor Green
    
    # 端口 8080 狀態
    $port8080 = netstat -ano | findstr ":8080"
    if ($port8080) {
        Write-Host "🔴 端口 8080: 被占用" -ForegroundColor Red
    } else {
        Write-Host "🟢 端口 8080: 可用" -ForegroundColor Green
    }
    
    Write-Host ""
}

function Start-ContinuousMonitoring {
    param([int]$IntervalSeconds = 30)
    
    Write-Host "🔄 開始連續監控 (每 $IntervalSeconds 秒更新一次)..." -ForegroundColor Cyan
    Write-Host "💡 按 Ctrl+C 停止監控" -ForegroundColor Blue
    
    while ($true) {
        Clear-Host
        Get-SystemStatus
        Start-Sleep -Seconds $IntervalSeconds
    }
}
```

