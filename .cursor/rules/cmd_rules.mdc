## 📝 使用指南與最佳實踐

### 日常維護流程
```powershell
# 每日開發前執行
function Start-DevDay {
    Write-Host "🌅 開始新的開發日..." -ForegroundColor Cyan
    
    # 系統狀態檢查
    Get-SystemStatus
    
    # 清理舊進程
    Stop-OldNodeProcesses -MaxRuntimeHours 12
    
    # 確保端口可用
    Test-Port8080
    
    # Git 安全檢查
    Test-GitSafety
    
    Write-Host "✅ 開發環境準備完成！" -ForegroundColor Green
}

# 每日開發後執行
function End-DevDay {
    Write-Host "🌙 結束開發日..." -ForegroundColor Cyan
    
    # 保存所有工作
    if (Test-GitSafety) {
        git add .
        git commit -m "🔧 每日工作保存 - $(Get-Date -Format 'yyyy-MM-dd HH:mm')"
    }
    
    # 清理資源
    Invoke-MasterCleanup
    
    Write-Host "✅ 開發環境清理完成！" -ForegroundColor Green
}
```

### 緊急修復指令
```powershell
# 緊急情況一鍵修復
function Invoke-EmergencyFix {
    Write-Host "🆘 緊急修復模式..." -ForegroundColor Red
    
    # 強制終止所有 Node.js
    Get-Process -Name "node" -ErrorAction SilentlyContinue | Stop-Process -Force
    
    # 清理所有鎖定
    Clear-GitLocks
    
    # 重置到乾淨狀態
    git reset --hard HEAD
    git clean -fd
    
    # 重新安裝依賴
    if (Test-Path "node_modules") {
        Remove-Item "node_modules" -Recurse -Force
    }
    npm install
    
    Write-Host "✅ 緊急修復完成！" -ForegroundColor Green
}
```

