## 🔧 Node.js 進程管理

### 進程檢查與清理
```powershell
# node-process-manager.ps1 - Node.js 進程管理工具
function Get-NodeProcesses {
    Write-Host "🔍 檢查 Node.js 進程..." -ForegroundColor Cyan
    
    $nodeProcesses = Get-Process -Name "node" -ErrorAction SilentlyContinue
    if ($nodeProcesses) {
        Write-Host "📊 發現 $($nodeProcesses.Count) 個 Node.js 進程:" -ForegroundColor Yellow
        
        foreach ($proc in $nodeProcesses) {
            $cpuUsage = [math]::Round($proc.CPU, 2)
            $memoryMB = [math]::Round($proc.WorkingSet / 1MB, 1)
            $runtime = (Get-Date) - $proc.StartTime
            
            Write-Host "  🟢 PID: $($proc.Id)" -ForegroundColor Green
            Write-Host "     📈 CPU: ${cpuUsage}s, 💾 記憶體: ${memoryMB}MB" -ForegroundColor Gray
            Write-Host "     ⏰ 運行時間: $($runtime.ToString('hh\:mm\:ss'))" -ForegroundColor Gray
            
            # 檢查是否為當前專案進程
            $cmdLine = (Get-WmiObject Win32_Process -Filter "ProcessId = $($proc.Id)").CommandLine
            if ($cmdLine -like "*PythonLearn-Zeabur*") {
                Write-Host "     ✅ 當前專案進程" -ForegroundColor Green
            } else {
                Write-Host "     ⚠️ 其他 Node.js 進程" -ForegroundColor Yellow
            }
            Write-Host ""
        }
    } else {
        Write-Host "✅ 無 Node.js 進程運行" -ForegroundColor Green
    }
}

function Stop-OldNodeProcesses {
    param([int]$MaxRuntimeHours = 2)
    
    Write-Host "🧹 清理運行超過 $MaxRuntimeHours 小時的 Node.js 進程..." -ForegroundColor Cyan
    
    $nodeProcesses = Get-Process -Name "node" -ErrorAction SilentlyContinue
    $cleanedCount = 0
    
    foreach ($proc in $nodeProcesses) {
        $runtime = (Get-Date) - $proc.StartTime
        if ($runtime.TotalHours -gt $MaxRuntimeHours) {
            $cmdLine = (Get-WmiObject Win32_Process -Filter "ProcessId = $($proc.Id)").CommandLine
            
            # 排除當前專案進程
            if ($cmdLine -notlike "*PythonLearn-Zeabur*") {
                Write-Host "🗑️ 終止舊進程 PID: $($proc.Id) (運行 $([math]::Round($runtime.TotalHours, 1)) 小時)" -ForegroundColor Red
                Stop-Process -Id $proc.Id -Force -ErrorAction SilentlyContinue
                $cleanedCount++
            }
        }
    }
    
    Write-Host "✅ 清理完成，終止了 $cleanedCount 個舊進程" -ForegroundColor Green
}
```

### 端口占用檢查與清理
```powershell
# port-manager.ps1 - 端口管理工具
function Test-Port8080 {
    Write-Host "🔍 檢查端口 8080 占用狀況..." -ForegroundColor Cyan
    
    $portCheck = netstat -ano | findstr ":8080"
    if ($portCheck) {
        Write-Host "⚠️ 端口 8080 被占用:" -ForegroundColor Yellow
        $portCheck | ForEach-Object { Write-Host "   $_" -ForegroundColor Gray }
        
        # 提取 PID 並獲取進程信息
        $pids = $portCheck | ForEach-Object {
            if ($_ -match '\s+(\d+)$') { $matches[1] }
        } | Select-Object -Unique
        
        foreach ($pid in $pids) {
            $process = Get-Process -Id $pid -ErrorAction SilentlyContinue
            if ($process) {
                Write-Host "   📋 進程: $($process.ProcessName) (PID: $pid)" -ForegroundColor Yellow
                
                $choice = Read-Host "是否終止此進程? (Y/N)"
                if ($choice -eq 'Y' -or $choice -eq 'y') {
                    Stop-Process -Id $pid -Force
                    Write-Host "✅ 進程 $pid 已終止" -ForegroundColor Green
                }
            }
        }
    } else {
        Write-Host "✅ 端口 8080 可用" -ForegroundColor Green
    }
}

function Clear-AllNode8080 {
    Write-Host "🧹 強制清理所有占用端口 8080 的 Node.js 進程..." -ForegroundColor Red
    
    $portCheck = netstat -ano | findstr ":8080"
    if ($portCheck) {
        $pids = $portCheck | ForEach-Object {
            if ($_ -match '\s+(\d+)$') { $matches[1] }
        } | Select-Object -Unique
        
        foreach ($pid in $pids) {
            $process = Get-Process -Id $pid -ErrorAction SilentlyContinue
            if ($process -and $process.ProcessName -eq "node") {
                Write-Host "🗑️ 終止 Node.js 進程 PID: $pid" -ForegroundColor Red
                Stop-Process -Id $pid -Force
            }
        }
        Write-Host "✅ 端口 8080 清理完成" -ForegroundColor Green
    } else {
        Write-Host "✅ 端口 8080 本來就是可用的" -ForegroundColor Green
    }
}
```

