## 🗂️ 系統資源清理

### 臨時檔案清理
```powershell
# temp-cleaner.ps1 - 臨時檔案清理工具
function Clear-TempFiles {
    Write-Host "🗑️ 清理臨時檔案..." -ForegroundColor Cyan
    
    $tempPaths = @(
        $env:TEMP,
        "$env:USERPROFILE\AppData\Local\Temp",
        ".\node_modules\.cache",
        ".\*.log",
        ".\*.tmp"
    )
    
    $totalCleaned = 0
    foreach ($path in $tempPaths) {
        if (Test-Path $path) {
            $files = Get-ChildItem $path -Force -ErrorAction SilentlyContinue
            if ($files) {
                $fileCount = $files.Count
                $files | Remove-Item -Force -Recurse -ErrorAction SilentlyContinue
                $totalCleaned += $fileCount
                Write-Host "🗑️ 清理 $path : $fileCount 個項目" -ForegroundColor Gray
            }
        }
    }
    
    Write-Host "✅ 臨時檔案清理完成，共清理 $totalCleaned 個項目" -ForegroundColor Green
}

function Clear-NodeModulesCache {
    Write-Host "🗑️ 清理 Node.js 快取..." -ForegroundColor Cyan
    
    if (Test-Path "node_modules") {
        $cacheSize = (Get-ChildItem "node_modules" -Recurse | Measure-Object -Property Length -Sum).Sum / 1MB
        Write-Host "📦 當前 node_modules 大小: $([math]::Round($cacheSize, 1)) MB" -ForegroundColor Yellow
        
        $choice = Read-Host "是否重新安裝依賴以清理快取? (Y/N)"
        if ($choice -eq 'Y' -or $choice -eq 'y') {
            Remove-Item "node_modules" -Recurse -Force
            Remove-Item "package-lock.json" -Force -ErrorAction SilentlyContinue
            npm install
            Write-Host "✅ Node.js 依賴重新安裝完成" -ForegroundColor Green
        }
    } else {
        Write-Host "✅ 無 node_modules 目錄需要清理" -ForegroundColor Green
    }
}
```

