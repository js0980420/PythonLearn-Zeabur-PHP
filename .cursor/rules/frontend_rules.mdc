## ⚙️ JavaScript 模組化規範

### ES6 模組標準
```javascript
// websocket.js - WebSocket 管理模組
class WebSocketManager {
    constructor() {
        this.ws = null;
        this.reconnectAttempts = 0;
        this.maxReconnectAttempts = 5;
        this.reconnectInterval = 1000;
        this.messageQueue = [];
        this.eventListeners = new Map();
    }
    
    /**
     * 建立 WebSocket 連接
     * @param {string} url - WebSocket 服務器地址
     * @returns {Promise} 連接狀態
     */
    connect(url) {
        return new Promise((resolve, reject) => {
            try {
                this.ws = new WebSocket(url);
                this.setupEventHandlers();
                
                this.ws.onopen = () => {
                    console.log('✅ WebSocket 連接成功');
                    this.reconnectAttempts = 0;
                    this.flushMessageQueue();
                    resolve(true);
                };
                
                this.ws.onerror = (error) => {
                    console.error('❌ WebSocket 連接錯誤:', error);
                    reject(error);
                };
            } catch (error) {
                reject(error);
            }
        });
    }
    
    /**
     * 發送消息
     * @param {Object} message - 要發送的消息對象
     */
    send(message) {
        if (this.isConnected()) {
            this.ws.send(JSON.stringify(message));
        } else {
            this.messageQueue.push(message);
            console.warn('⚠️ WebSocket 未連接，消息已加入佇列');
        }
    }
    
    /**
     * 檢查連接狀態
     * @returns {boolean} 連接狀態
     */
    isConnected() {
        return this.ws && this.ws.readyState === WebSocket.OPEN;
    }
    
    /**
     * 註冊事件監聽器
     * @param {string} event - 事件名稱
     * @param {Function} callback - 回調函數
     */
    on(event, callback) {
        if (!this.eventListeners.has(event)) {
            this.eventListeners.set(event, []);
        }
        this.eventListeners.get(event).push(callback);
    }
    
    /**
     * 觸發事件
     * @param {string} event - 事件名稱
     * @param {*} data - 事件數據
     */
    emit(event, data) {
        if (this.eventListeners.has(event)) {
            this.eventListeners.get(event).forEach(callback => {
                try {
                    callback(data);
                } catch (error) {
                    console.error(`❌ 事件處理錯誤 [${event}]:`, error);
                }
            });
        }
    }
    
    // 私有方法
    setupEventHandlers() {
        this.ws.onmessage = (event) => {
            try {
                const message = JSON.parse(event.data);
                this.emit(message.type, message);
            } catch (error) {
                console.error('❌ 消息解析錯誤:', error);
            }
        };
        
        this.ws.onclose = () => {
            console.warn('⚠️ WebSocket 連接關閉');
            this.attemptReconnect();
        };
    }
    
    flushMessageQueue() {
        while (this.messageQueue.length > 0 && this.isConnected()) {
            const message = this.messageQueue.shift();
            this.send(message);
        }
    }
    
    attemptReconnect() {
        if (this.reconnectAttempts < this.maxReconnectAttempts) {
            this.reconnectAttempts++;
            console.log(`🔄 嘗試重連 (${this.reconnectAttempts}/${this.maxReconnectAttempts})`);
            
            setTimeout(() => {
                // 重連邏輯
            }, this.reconnectInterval * this.reconnectAttempts);
        }
    }
}

// 創建全局 WebSocket 管理器實例
const wsManager = new WebSocketManager();
```

### 全域變數管理
```javascript
// ui.js - UI 管理和全域變數
const UI = {
    // 📊 應用狀態
    state: {
        currentUser: null,
        currentRoom: null,
        isConnected: false,
        isEditing: false
    },
    
    // 🎨 UI 元素快取
    elements: {
        roomForm: null,
        editor: null,
        chatMessages: null,
        userList: null
    },
    
    // 🚀 初始化方法
    init() {
        this.cacheElements();
        this.bindEvents();
        this.setupToasts();
        console.log('✅ UI 管理器初始化完成');
    },
    
    // 📱 元素快取
    cacheElements() {
        this.elements.roomForm = document.getElementById('room-form');
        this.elements.editor = document.getElementById('code-editor');
        this.elements.chatMessages = document.getElementById('chat-messages');
        this.elements.userList = document.getElementById('user-list');
    },
    
    // 🔗 事件綁定
    bindEvents() {
        // 房間表單提交
        if (this.elements.roomForm) {
            this.elements.roomForm.addEventListener('submit', (e) => {
                e.preventDefault();
                this.handleRoomJoin();
            });
        }
        
        // 全域鍵盤快捷鍵
        document.addEventListener('keydown', (e) => {
            this.handleGlobalKeydown(e);
        });
    },
    
    // ⌨️ 全域鍵盤事件處理
    handleGlobalKeydown(e) {
        // Ctrl+S: 保存代碼
        if (e.ctrlKey && e.key === 's') {
            e.preventDefault();
            if (window.editor && typeof window.editor.saveCode === 'function') {
                window.editor.saveCode();
            }
        }
        
        // Ctrl+Enter: 運行代碼
        if (e.ctrlKey && e.key === 'Enter') {
            e.preventDefault();
            if (window.editor && typeof window.editor.runCode === 'function') {
                window.editor.runCode();
            }
        }
    },
    
    // 🎉 成功提示
    showSuccessToast(message) {
        this.showToast(message, 'success');
    },
    
    // ❌ 錯誤提示
    showErrorToast(message) {
        this.showToast(message, 'error');
    },
    
    // ℹ️ 信息提示
    showInfoToast(message) {
        this.showToast(message, 'info');
    },
    
    // 🔔 通用提示方法
    showToast(message, type = 'info') {
        const toastContainer = this.getToastContainer();
        const toast = this.createToastElement(message, type);
        
        toastContainer.appendChild(toast);
        
        // 自動消失
        setTimeout(() => {
            toast.remove();
        }, 5000);
        
        // 點擊關閉
        toast.querySelector('.btn-close')?.addEventListener('click', () => {
            toast.remove();
        });
    },
    
    // 📝 創建提示元素
    createToastElement(message, type) {
        const toast = document.createElement('div');
        toast.className = `toast align-items-center text-white bg-${type} border-0`;
        toast.setAttribute('role', 'alert');
        toast.setAttribute('aria-live', 'assertive');
        toast.setAttribute('aria-atomic', 'true');
        
        toast.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">
                    ${message}
                </div>
                <button type="button" 
                        class="btn-close btn-close-white me-2 m-auto" 
                        aria-label="關閉">
                </button>
            </div>
        `;
        
        return toast;
    },
    
    // 📦 獲取提示容器
    getToastContainer() {
        let container = document.getElementById('toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toast-container';
            container.className = 'toast-container position-fixed top-0 end-0 p-3';
            container.style.zIndex = '1055';
            document.body.appendChild(container);
        }
        return container;
    },
    
    // 🔄 更新應用狀態
    updateState(newState) {
        Object.assign(this.state, newState);
        this.renderStateChanges();
    },
    
    // 🎨 渲染狀態變化
    renderStateChanges() {
        // 更新連接狀態指示器
        const statusIndicator = document.querySelector('.connection-status');
        if (statusIndicator) {
            statusIndicator.className = `connection-status ${this.state.isConnected ? 'connected' : 'disconnected'}`;
            statusIndicator.textContent = this.state.isConnected ? '已連接' : '未連接';
        }
        
        // 更新當前用戶顯示
        const userDisplay = document.querySelector('.current-user');
        if (userDisplay && this.state.currentUser) {
            userDisplay.textContent = this.state.currentUser;
        }
    }
};

// 全域方法導出
window.UI = UI;

// 🚀 DOM 載入完成後初始化
document.addEventListener('DOMContentLoaded', () => {
    UI.init();
});
