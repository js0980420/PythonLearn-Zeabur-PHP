## 🔧 組件開發規範

### 編輯器組件
```javascript
// editor.js - 代碼編輯器組件
class CodeEditor {
    constructor(containerId, options = {}) {
        this.containerId = containerId;
        this.editor = null;
        this.currentVersion = 1;
        this.isInitialized = false;
        
        // 🎯 默認配置
        this.config = {
            mode: 'python',
            theme: 'monokai',
            lineNumbers: true,
            indentUnit: 4,
            autoCloseBrackets: true,
            matchBrackets: true,
            lineWrapping: true,
            ...options
        };
        
        this.init();
    }
    
    /**
     * 初始化編輯器
     */
    init() {
        const container = document.getElementById(this.containerId);
        if (!container) {
            console.error(`❌ 找不到編輯器容器: ${this.containerId}`);
            return;
        }
        
        // 創建編輯器實例
        this.editor = CodeMirror(container, this.config);
        
        // 設置事件監聽
        this.setupEventListeners();
        
        this.isInitialized = true;
        console.log('✅ 代碼編輯器初始化完成');
    }
    
    /**
     * 設置事件監聽器
     */
    setupEventListeners() {
        // 內容變化事件
        this.editor.on('change', (instance, changeObj) => {
            this.handleContentChange(changeObj);
        });
        
        // 光標位置變化事件
        this.editor.on('cursorActivity', (instance) => {
            this.handleCursorChange();
        });
        
        // 焦點事件
        this.editor.on('focus', () => {
            UI.updateState({ isEditing: true });
        });
        
        this.editor.on('blur', () => {
            UI.updateState({ isEditing: false });
        });
    }
    
    /**
     * 處理內容變化
     * @param {Object} changeObj - 變化對象
     */
    handleContentChange(changeObj) {
        if (changeObj.origin !== 'setValue') {
            // 發送代碼變更到服務器
            const message = {
                type: 'code_change',
                code: this.getValue(),
                version: ++this.currentVersion,
                timestamp: Date.now()
            };
            
            if (wsManager.isConnected()) {
                wsManager.send(message);
            }
        }
    }
    
    /**
     * 處理光標變化
     */
    handleCursorChange() {
        const cursor = this.editor.getCursor();
        const message = {
            type: 'cursor_change',
            line: cursor.line,
            ch: cursor.ch,
            timestamp: Date.now()
        };
        
        if (wsManager.isConnected()) {
            wsManager.send(message);
        }
    }
    
    /**
     * 獲取編輯器內容
     * @returns {string} 編輯器內容
     */
    getValue() {
        return this.editor ? this.editor.getValue() : '';
    }
    
    /**
     * 設置編輯器內容
     * @param {string} value - 要設置的內容
     */
    setValue(value) {
        if (this.editor) {
            this.editor.setValue(value || '');
        }
    }
    
    /**
     * 保存代碼
     * @param {string} operation - 操作類型
     * @param {string} fileName - 檔案名稱
     */
    saveCode(operation = 'manual', fileName = '未命名') {
        if (!wsManager.isConnected()) {
            UI.showErrorToast('未連接到服務器，無法保存');
            return;
        }
        
        const message = {
            type: 'save_code',
            operation: operation,
            fileName: fileName,
            code: this.getValue(),
            timestamp: Date.now(),
            version: this.currentVersion + 1
        };
        
        wsManager.send(message);
        UI.showInfoToast('代碼保存中...');
    }
    
    /**
     * 載入代碼
     * @param {string} loadType - 載入類型
     */
    loadCode(loadType = 'latest') {
        if (!wsManager.isConnected()) {
            UI.showErrorToast('未連接到服務器，無法載入');
            return;
        }
        
        const message = {
            type: 'load_code',
            loadType: loadType,
            requestedVersion: loadType === 'latest' ? null : parseInt(loadType)
        };
        
        wsManager.send(message);
        UI.showInfoToast('正在載入代碼...');
    }
    
    /**
     * 運行代碼
     */
    runCode() {
        const code = this.getValue().trim();
        if (!code) {
            UI.showErrorToast('請先輸入代碼');
            return;
        }
        
        if (!wsManager.isConnected()) {
            UI.showErrorToast('未連接到服務器，無法運行代碼');
            return;
        }
        
        const message = {
            type: 'run_code',
            code: code,
            timestamp: Date.now()
        };
        
        wsManager.send(message);
        UI.showInfoToast('代碼執行中...');
    }
}

