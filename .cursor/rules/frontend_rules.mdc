            </form>
        `;
        
        // 執行初始化
        UI.init();
        
        // 驗證結果
        expect(UI.elements.roomForm).toBeTruthy();
        expect(UI.elements.roomForm.id).toBe('room-form');
    });
    
    test('應該正確顯示成功提示', () => {
        const testMessage = '測試成功訊息';
        
        UI.showSuccessToast(testMessage);
        
        const toast = document.querySelector('.toast');
        expect(toast).toBeTruthy();
        expect(toast.textContent).toContain(testMessage);
        expect(toast.classList.contains('bg-success')).toBe(true);
    });
    
    test('應該正確更新應用狀態', () => {
        const newState = {
            currentUser: '測試用戶',
            isConnected: true
        };
        
        UI.updateState(newState);
        
        expect(UI.state.currentUser).toBe('測試用戶');
        expect(UI.state.isConnected).toBe(true);
    });
});
