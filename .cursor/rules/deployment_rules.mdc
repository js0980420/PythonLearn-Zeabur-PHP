## 📁 檔案架構驗證規範

### 15檔案架構強制檢查
```powershell
# 檢查檔案數量和結構
$git_files = git ls-files
$file_count = $git_files.Count

Write-Host "📊 檔案數量檢查..."
if ($file_count -eq 15) {
    Write-Host "✅ 檔案數量正確: $file_count"
} else {
    Write-Host "❌ 檔案數量錯誤: $file_count (應該是15個)"
    Write-Host "📋 當前追蹤的檔案:"
    $git_files | ForEach-Object { Write-Host "  - $_" }
    exit 1
}

# 檢查必需檔案
$required_files = @(
    "server.js",
    "package.json", 
    "package-lock.json",
    "zeabur.yaml",
    "public/index.html",
    "public/teacher-dashboard.html",
    "public/config.html",
    "public/css/styles.css",
    "public/favicon.ico",
    "public/js/ai-assistant.js",
    "public/js/chat.js",
    "public/js/conflict.js",
    "public/js/editor.js",
    "public/js/ui.js",
    "public/js/websocket.js"
)

$missing_files = @()
foreach ($file in $required_files) {
    if (-not (Test-Path $file)) {
        $missing_files += $file
    }
}

if ($missing_files.Count -gt 0) {
    Write-Host "❌ 缺少必需檔案:"
    $missing_files | ForEach-Object { Write-Host "  - $_" }
    exit 1
} else {
    Write-Host "✅ 所有必需檔案存在"
}
```

### 禁止檔案檢查
```powershell
# 檢查是否包含禁止的檔案類型
$forbidden_patterns = @(
    "*.md",
    "README*",
    ".gitignore",
    ".env*",
    "node_modules/*",
    "*.log",
    "*.tmp"
)

$forbidden_files = @()
foreach ($pattern in $forbidden_patterns) {
    $matches = git ls-files | Where-Object { $_ -like $pattern }
    if ($matches) {
        $forbidden_files += $matches
    }
}

if ($forbidden_files.Count -gt 0) {
    Write-Host "❌ 發現禁止的檔案:"
    $forbidden_files | ForEach-Object { Write-Host "  - $_" }
    exit 1
} else {
    Write-Host "✅ 無禁止檔案"
}
```

