## 📊 部署後驗證規範

### 自動化部署驗證腳本
```powershell
# 部署後自動驗證
param(
    [string]$DeploymentUrl = "https://your-app.zeabur.app"
)

Write-Host "🔍 開始部署後驗證..."

# 等待服務啟動
Write-Host "⏳ 等待服務啟動 (60秒)..."
Start-Sleep -Seconds 60

# 檢查基本可用性
try {
    $response = Invoke-WebRequest -Uri $DeploymentUrl -TimeoutSec 30
    if ($response.StatusCode -eq 200) {
        Write-Host "✅ 部署成功，服務可用"
    } else {
        Write-Host "⚠️ 服務回應異常，狀態碼: $($response.StatusCode)"
    }
} catch {
    Write-Host "❌ 服務不可用: $($_.Exception.Message)"
    exit 1
}

# 檢查關鍵功能端點
$test_endpoints = @(
    "/teacher",
    "/config"
)

foreach ($endpoint in $test_endpoints) {
    try {
        $test_response = Invoke-WebRequest -Uri "$DeploymentUrl$endpoint" -TimeoutSec 15
        Write-Host "✅ 端點 $endpoint 正常 (狀態: $($test_response.StatusCode))"
    } catch {
        Write-Host "❌ 端點 $endpoint 異常: $($_.Exception.Message)"
    }
}

Write-Host "🎉 部署驗證完成"
```

