## 🌐 Zeabur 部署規範

### zeabur.yaml 配置驗證
```powershell
# 檢查 Zeabur 部署配置
if (Test-Path "zeabur.yaml") {
    Write-Host "✅ zeabur.yaml 配置檔存在"
    
    # 檢查配置內容
    $zeabur_config = Get-Content "zeabur.yaml" -Raw
    
    # 檢查必要配置項
    $required_configs = @(
        "name:",
        "services:",
        "ports:"
    )
    
    foreach ($config in $required_configs) {
        if ($zeabur_config -match $config) {
            Write-Host "✅ 包含配置: $config"
        } else {
            Write-Host "⚠️ 缺少配置: $config"
        }
    }
} else {
    Write-Host "❌ zeabur.yaml 配置檔不存在"
    exit 1
}
```

### Git 推送前最後檢查
```powershell
# Git 狀態檢查
$git_status = git status --porcelain
if ($git_status) {
    Write-Host "📝 發現未提交的變更:"
    $git_status | ForEach-Object { Write-Host "  $_" }
    
    $commit_choice = Read-Host "是否提交所有變更? [Y/n]"
    if ($commit_choice.ToUpper() -ne "N") {
        git add .
        $commit_message = Read-Host "輸入提交訊息 (預設: 🚀 部署更新)"
        if ([string]::IsNullOrEmpty($commit_message)) {
            $commit_message = "🚀 部署更新"
        }
        git commit -m $commit_message
        Write-Host "✅ 變更已提交"
    }
} else {
    Write-Host "✅ Git 狀態乾淨"
}

# 推送到遠端倉庫
Write-Host "📤 推送到遠端倉庫..."
try {
    git push origin main
    Write-Host "✅ 推送成功"
} catch {
    Write-Host "❌ 推送失敗: $($_.Exception.Message)"
    exit 1
}
```

