## ⚙️ 環境配置驗證

### 關鍵環境變數檢查
```powershell
# 檢查必要的環境變數
$required_env_vars = @{
    "OPENAI_API_KEY" = "OpenAI API 密鑰"
    "MYSQL_HOST" = "MySQL 主機地址"  
    "MYSQL_USER" = "MySQL 用戶名"
    "MYSQL_PASSWORD" = "MySQL 密碼"
    "MYSQL_DATABASE" = "MySQL 數據庫名"
}

Write-Host "🔐 環境變數檢查..."
$missing_vars = @()
foreach ($var in $required_env_vars.Keys) {
    $value = [Environment]::GetEnvironmentVariable($var)
    if ([string]::IsNullOrEmpty($value)) {
        $missing_vars += $var
        Write-Host "⚠️ 缺少環境變數: $var ($($required_env_vars[$var]))"
    } else {
        # 遮蔽敏感資料顯示
        $masked_value = if ($var -like "*KEY*" -or $var -like "*PASSWORD*") { 
            "*" * 8 + $value.Substring([Math]::Max(0, $value.Length - 4))
        } else { 
            $value 
        }
        Write-Host "✅ $var = $masked_value"
    }
}

if ($missing_vars.Count -gt 0) {
    Write-Host "ℹ️ 部分環境變數缺失，將使用本地模式"
} else {
    Write-Host "✅ 所有環境變數配置完整"
}
```

### package.json 依賴檢查
```powershell
# 檢查package.json配置
if (Test-Path "package.json") {
    $package_json = Get-Content "package.json" | ConvertFrom-Json
    
    # 檢查必要的依賴
    $required_deps = @(
        "express",
        "socket.io", 
        "mysql2",
        "openai"
    )
    
    $missing_deps = @()
    foreach ($dep in $required_deps) {
        if (-not $package_json.dependencies.$dep) {
            $missing_deps += $dep
        }
    }
    
    if ($missing_deps.Count -gt 0) {
        Write-Host "❌ 缺少必要依賴:"
        $missing_deps | ForEach-Object { Write-Host "  - $_" }
        exit 1
    } else {
        Write-Host "✅ 所有必要依賴已配置"
    }
    
    # 檢查啟動腳本
    if ($package_json.scripts.start) {
        Write-Host "✅ 啟動腳本已配置: $($package_json.scripts.start)"
    } else {
        Write-Host "⚠️ 缺少啟動腳本配置"
    }
} else {
    Write-Host "❌ package.json 檔案不存在"
    exit 1
}
```

