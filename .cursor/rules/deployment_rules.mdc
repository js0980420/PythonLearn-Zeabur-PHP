## 🔍 本地驗證階段規範

### 端口占用檢查標準流程
```powershell
# 1. 檢查當前端口使用狀況
netstat -ano | findstr :8080
if ($LASTEXITCODE -eq 0) {
    Write-Host "⚠️ 警告：端口8080被占用"
    # 顯示占用進程詳細資訊
    netstat -ano | findstr :8080 | ForEach-Object {
        $port_info = $_ -split '\s+'
        $pid = $port_info[-1]
        $process = Get-Process -Id $pid -ErrorAction SilentlyContinue
        if ($process) {
            Write-Host "📋 進程名稱: $($process.ProcessName)"
            Write-Host "🆔 進程ID: $pid"
            Write-Host "⏰ 啟動時間: $($process.StartTime)"
        }
    }
} else {
    Write-Host "✅ 端口8080可用"
}
```

### 多進程問題處理機制
```powershell
# 2. 檢查並處理多個Node.js進程
$node_processes = Get-Process -Name "node" -ErrorAction SilentlyContinue
if ($node_processes.Count -gt 0) {
    Write-Host "🔍 發現 $($node_processes.Count) 個Node.js進程:"
    $node_processes | ForEach-Object {
        Write-Host "  - PID: $($_.Id), 記憶體: $([math]::Round($_.WorkingSet/1MB))MB, 啟動: $($_.StartTime)"
    }
    
    # 用戶選擇處理方式
    $choice = Read-Host "選擇操作: [K]終止所有, [S]選擇性終止, [C]繼續 (預設: C)"
    switch ($choice.ToUpper()) {
        "K" { 
            $node_processes | Stop-Process -Force
            Write-Host "✅ 已終止所有Node.js進程"
        }
        "S" {
            $node_processes | ForEach-Object {
                $confirm = Read-Host "終止進程 $($_.Id) ($($_.ProcessName))? [y/N]"
                if ($confirm.ToUpper() -eq "Y") {
                    Stop-Process -Id $_.Id -Force
                    Write-Host "✅ 已終止進程 $($_.Id)"
                }
            }
        }
        default { Write-Host "ℹ️ 保持現有進程運行" }
    }
}
```

### 服務啟動驗證
```powershell
# 3. 啟動服務並驗證
Write-Host "🚀 啟動服務..."
$job = Start-Job -ScriptBlock { 
    Set-Location $using:PWD
    npm start 
}

# 等待服務啟動
Start-Sleep -Seconds 5

# 驗證服務可用性
try {
    $response = Invoke-WebRequest -Uri "http://localhost:8080" -TimeoutSec 10
    if ($response.StatusCode -eq 200) {
        Write-Host "✅ 服務啟動成功，狀態碼: $($response.StatusCode)"
        
        # 測試關鍵功能端點
        $endpoints = @(
            "/teacher",
            "/config"
        )
        
        foreach ($endpoint in $endpoints) {
            try {
                $test_response = Invoke-WebRequest -Uri "http://localhost:8080$endpoint" -TimeoutSec 5
                Write-Host "✅ 端點 $endpoint 可用 (狀態: $($test_response.StatusCode))"
            } catch {
                Write-Host "⚠️ 端點 $endpoint 不可用: $($_.Exception.Message)"
            }
        }
    }
} catch {
    Write-Host "❌ 服務啟動失敗: $($_.Exception.Message)"
    Stop-Job -Job $job
    exit 1
} finally {
    Stop-Job -Job $job -ErrorAction SilentlyContinue
}
```

