## 🛠️ 檔案操作功能實現

### 下載功能 (downloadCode)
```javascript
// public/js/editor.js - 下載代碼為 .py 檔案
downloadCode() {
    const code = this.editor.getValue();
    const filename = prompt('請輸入檔案名稱 (不需要 .py 副檔名):', 'my_python_code') || 'my_python_code';
    const blob = new Blob([code], { type: 'text/plain' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${filename}.py`;
    a.click();
    window.URL.revokeObjectURL(url);
}
```

### 複製功能 (copyCode)
```javascript
// 支援現代瀏覽器 Clipboard API + 傳統 execCommand 回退
copyCode() {
    const code = this.editor.getValue();
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(code).then(() => {
            UI.showSuccessToast('代碼已複製到剪貼簿');
        }).catch(() => {
            this.fallbackCopy(code);
        });
    } else {
        this.fallbackCopy(code);
    }
}
```

### 導入功能 (importCode + handleFileImport)
```javascript
// 支援 .py 和 .txt 檔案，1MB 大小限制
importCode() {
    const fileInput = document.getElementById('file-import');
    if (fileInput) {
        fileInput.click();
    }
}

handleFileImport(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    // 檔案類型檢查
    const validTypes = ['.py', '.txt', 'text/plain', 'text/x-python'];
    // 大小限制檢查 (1MB)
    if (file.size > 1024 * 1024) {
        UI.showErrorToast('檔案大小不能超過 1MB');
        return;
    }
    
    // 覆蓋確認機制
    if (this.editor.getValue().trim()) {
        if (!confirm('當前編輯器有內容，是否要覆蓋？')) {
            return;
        }
    }
    
    const reader = new FileReader();
    reader.onload = (e) => {
        this.editor.setValue(e.target.result);
        UI.showSuccessToast(`檔案 "${file.name}" 載入成功`);
    };
    reader.readAsText(file);
}
```

