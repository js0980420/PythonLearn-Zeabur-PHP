## 實時監控實現

### WebSocket監控連接
```javascript
// 教師監控WebSocket連接
const monitorSocket = new WebSocket('ws://localhost:8080/monitor');

monitorSocket.onopen = function() {
  // 註冊為教師監控連接
  monitorSocket.send(JSON.stringify({
    type: 'register_monitor',
    teacher_id: teacherId,
    auth_token: authToken
  }));
};

monitorSocket.onmessage = function(event) {
  const data = JSON.parse(event.data);
  
  switch(data.type) {
    case 'room_update':
      updateRoomInfo(data.room_data);
      break;
    case 'student_activity':
      updateStudentActivity(data.activity);
      break;
    case 'code_change':
      updateCodePreview(data.room_id, data.code);
      break;
  }
};
```

### 監控數據收集
```php
// WebSocket服務器端監控數據廣播
class MonitorHandler {
    private $teachers = [];
    
    public function registerTeacher($connection, $teacherId) {
        $this->teachers[$teacherId] = $connection;
    }
    
    public function broadcastToTeachers($data) {
        foreach ($this->teachers as $connection) {
            $connection->send(json_encode($data));
        }
    }
    
    public function onStudentActivity($roomId, $userId, $activity) {
        $monitorData = [
            'type' => 'student_activity',
            'room_id' => $roomId,
            'user_id' => $userId,
            'activity' => $activity,
            'timestamp' => date('c')
        ];
        
        $this->broadcastToTeachers($monitorData);
    }
}
```

