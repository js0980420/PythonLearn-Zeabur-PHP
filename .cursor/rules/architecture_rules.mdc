## 🔄 檔案架構驗證系統

### 自動檢查腳本
```powershell
# architecture-check.ps1
function Test-FileArchitecture {
    Write-Host "🏗️ 開始檔案架構檢查..."
    
    # 1. 檢查檔案總數
    $git_files = git ls-files
    $file_count = $git_files.Count
    
    if ($file_count -ne 15) {
        Write-Host "❌ 檔案數量錯誤: $file_count (應該是15個)" -ForegroundColor Red
        return $false
    }
    Write-Host "✅ 檔案數量正確: $file_count" -ForegroundColor Green
    
    # 2. 檢查必需檔案存在
    $required_files = @(
        'server.js', 'package.json', 'package-lock.json', 'zeabur.yaml',
        'public/index.html', 'public/teacher-dashboard.html', 'public/config.html',
        'public/css/styles.css', 'public/favicon.ico',
        'public/js/ai-assistant.js', 'public/js/chat.js', 'public/js/conflict.js',
        'public/js/editor.js', 'public/js/ui.js', 'public/js/websocket.js'
    )
    
    $missing_files = @()
    foreach ($file in $required_files) {
        if (-not (Test-Path $file)) {
            $missing_files += $file
        }
    }
    
    if ($missing_files.Count -gt 0) {
        Write-Host "❌ 缺少必需檔案:" -ForegroundColor Red
        $missing_files | ForEach-Object { Write-Host "  - $_" -ForegroundColor Red }
        return $false
    }
    Write-Host "✅ 所有必需檔案存在" -ForegroundColor Green
    
    # 3. 檢查禁止檔案
    $forbidden_patterns = @('*.md', 'README*', '.gitignore', '.env*', 'Dockerfile')
    $forbidden_files = @()
    
    foreach ($pattern in $forbidden_patterns) {
        $matches = git ls-files | Where-Object { $_ -like $pattern }
        if ($matches) {
            $forbidden_files += $matches
        }
    }
    
    if ($forbidden_files.Count -gt 0) {
        Write-Host "❌ 發現禁止檔案:" -ForegroundColor Red
        $forbidden_files | ForEach-Object { Write-Host "  - $_" -ForegroundColor Red }
        return $false
    }
    Write-Host "✅ 無禁止檔案" -ForegroundColor Green
    
    # 4. 檢查目錄結構
    $forbidden_dirs = @('node_modules', 'dist', 'src', 'docs', 'test')
    $existing_forbidden_dirs = @()
    
    foreach ($dir in $forbidden_dirs) {
        if (Test-Path $dir) {
            $existing_forbidden_dirs += $dir
        }
    }
    
    if ($existing_forbidden_dirs.Count -gt 0) {
        Write-Host "❌ 發現禁止目錄:" -ForegroundColor Red
        $existing_forbidden_dirs | ForEach-Object { Write-Host "  - $_" -ForegroundColor Red }
        return $false
    }
    Write-Host "✅ 目錄結構正確" -ForegroundColor Green
    
    Write-Host "🎉 檔案架構檢查通過" -ForegroundColor Green
    return $true
}
```

### 架構修復工具
```powershell
# architecture-fix.ps1
function Repair-FileArchitecture {
    Write-Host "🔧 開始修復檔案架構..."
    
    # 1. 清理Git索引
    Write-Host "🧹 清理Git索引..."
    git rm --cached -r . 2>$null
    
    # 2. 添加核心檔案
    Write-Host "📁 添加核心檔案..."
    $core_files = @('server.js', 'package.json', 'package-lock.json', 'zeabur.yaml')
    foreach ($file in $core_files) {
        if (Test-Path $file) {
            git add $file
            Write-Host "  ✅ 添加: $file" -ForegroundColor Green
        } else {
            Write-Host "  ❌ 檔案不存在: $file" -ForegroundColor Red
        }
    }
    
    # 3. 添加前端檔案
    Write-Host "🌐 添加前端檔案..."
    $frontend_files = @(
        'public/index.html', 'public/teacher-dashboard.html', 'public/config.html',
        'public/css/styles.css', 'public/favicon.ico'
    )
    foreach ($file in $frontend_files) {
        if (Test-Path $file) {
            git add $file
            Write-Host "  ✅ 添加: $file" -ForegroundColor Green
        } else {
            Write-Host "  ❌ 檔案不存在: $file" -ForegroundColor Red
        }
    }
    
    # 4. 添加JavaScript模組
    Write-Host "⚡ 添加JavaScript模組..."
    $js_files = @(
        'public/js/ai-assistant.js', 'public/js/chat.js', 'public/js/conflict.js',
        'public/js/editor.js', 'public/js/ui.js', 'public/js/websocket.js'
    )
    foreach ($file in $js_files) {
        if (Test-Path $file) {
            git add $file
            Write-Host "  ✅ 添加: $file" -ForegroundColor Green
        } else {
            Write-Host "  ❌ 檔案不存在: $file" -ForegroundColor Red
        }
    }
    
    # 5. 最終檢查
    $final_count = (git ls-files).Count
    Write-Host "📊 最終檔案數量: $final_count"
    
    if ($final_count -eq 15) {
        Write-Host "✅ 架構修復成功" -ForegroundColor Green
    } else {
        Write-Host "⚠️ 架構修復不完整，檔案數量: $final_count" -ForegroundColor Yellow
    }
}
```

