## 🚨 故障檢測與恢復

### 連接監控機制
```javascript
// 定期健康檢查
setInterval(async () => {
    const isHealthy = await checkDatabaseHealth();
    
    if (!isHealthy && dataManager.isCloudMode) {
        console.log('⚠️ MySQL連接失敗，準備降級到本地模式');
        await dataManager.degradeToLocalMode();
    } else if (isHealthy && !dataManager.isCloudMode) {
        console.log('🌐 MySQL連接恢復，準備升級到雲端模式');
        await dataManager.upgradeToCloudMode();
    }
}, 30000); // 每30秒檢查一次
```

### 自動恢復策略
```javascript
class RecoveryManager {
    async degradeToLocalMode() {
        console.log('🔄 開始降級到本地模式...');
        
        try {
            // 嘗試從雲端同步最新數據到本地
            await this.syncCloudToLocal();
        } catch (error) {
            console.log('⚠️ 數據同步失敗，使用現有本地數據');
        }
        
        dataManager.isCloudMode = false;
        console.log('✅ 已降級到本地模式');
    }

    async upgradeToCloudMode() {
        console.log('🔄 開始升級到雲端模式...');
        
        try {
            // 將本地數據同步到雲端
            await this.syncLocalToCloud();
            dataManager.isCloudMode = true;
            console.log('✅ 已升級到雲端模式');
        } catch (error) {
            console.log('❌ 升級失敗，保持本地模式:', error.message);
        }
    }

    async syncLocalToCloud() {
        // 同步用戶數據
        for (const [userId, userData] of dataManager.localData.users) {
            await userManager.createUser(userData.username, userData.displayName, userData.role);
        }

        // 同步房間數據
        for (const [roomId, roomData] of dataManager.localData.rooms) {
            await roomManager.createRoom(roomId, roomData.name, roomData.teacherId);
        }

        // 同步代碼版本
        for (const [roomId, versions] of dataManager.localData.codeVersions) {
            for (const version of versions) {
                await codeVersionManager.saveCode(
                    roomId, 
                    version.code, 
                    version.userId, 
                    version.operation, 
                    version.fileName
                );
            }
        }
    }
}
```

