## 🔐 安全性配置

### SQL注入防護
```javascript
// 使用參數化查詢防止SQL注入
async function searchUsers(searchTerm) {
    if (dataManager.isCloudMode) {
        // ✅ 安全的參數化查詢
        const query = `
            SELECT id, username, display_name, role
            FROM users 
            WHERE username LIKE ? OR display_name LIKE ?
            LIMIT 20
        `;
        const searchPattern = `%${searchTerm}%`;
        const [rows] = await pool.execute(query, [searchPattern, searchPattern]);
        return rows;
    } else {
        return Array.from(dataManager.localData.users.values())
            .filter(user => 
                user.username.includes(searchTerm) || 
                user.displayName.includes(searchTerm)
            )
            .slice(0, 20);
    }
}
```

### 敏感資料保護
```javascript
// 環境變數驗證
function validateDatabaseConfig() {
    const requiredVars = ['MYSQL_HOST', 'MYSQL_USER', 'MYSQL_DATABASE'];
    const missingVars = requiredVars.filter(varName => !process.env[varName]);
    
    if (missingVars.length > 0) {
        console.log(`⚠️ 缺少必要的環境變數: ${missingVars.join(', ')}`);
        console.log('🏠 將使用本地存儲模式');
        return false;
    }
    
    // 檢查密碼強度
    const password = process.env.MYSQL_PASSWORD;
    if (password && password.length < 8) {
        console.log('⚠️ MySQL密碼強度不足，建議使用8位以上密碼');
    }
    
    return true;
}
```

