## 📈 性能優化策略

### 查詢優化
```javascript
// 分頁查詢優化
async function getChatHistory(roomId, page = 1, limit = 50) {
    if (dataManager.isCloudMode) {
        const offset = (page - 1) * limit;
        const query = `
            SELECT cm.*, u.display_name
            FROM chat_messages cm
            LEFT JOIN users u ON cm.user_id = u.id
            WHERE cm.room_id = ?
            ORDER BY cm.timestamp DESC
            LIMIT ? OFFSET ?
        `;
        const [rows] = await pool.execute(query, [roomId, limit, offset]);
        return rows.reverse(); // 按時間正序返回
    } else {
        const messages = dataManager.localData.messages
            .filter(msg => msg.roomId === roomId)
            .slice(-limit * page)
            .slice(-limit);
        return messages;
    }
}

// 批量插入優化
async function batchInsertMessages(messages) {
    if (dataManager.isCloudMode && messages.length > 0) {
        const values = messages.map(msg => [msg.roomId, msg.userId, msg.username, msg.message, msg.messageType]);
        const placeholders = messages.map(() => '(?, ?, ?, ?, ?)').join(', ');
        const query = `
            INSERT INTO chat_messages (room_id, user_id, username, message, message_type)
            VALUES ${placeholders}
        `;
        await pool.execute(query, values.flat());
    }
}
```

