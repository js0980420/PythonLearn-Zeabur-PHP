## 📊 數據庫表結構設計

### 核心數據表定義
```sql
-- 用戶表
CREATE TABLE IF NOT EXISTS users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) NOT NULL UNIQUE,
    display_name VARCHAR(100),
    role ENUM('student', 'teacher') DEFAULT 'student',
    last_active TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_username (username),
    INDEX idx_role (role)
);

-- 房間表
CREATE TABLE IF NOT EXISTS rooms (
    id VARCHAR(50) PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    teacher_id INT,
    max_users INT DEFAULT 5,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    last_activity TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_active BOOLEAN DEFAULT TRUE,
    FOREIGN KEY (teacher_id) REFERENCES users(id) ON DELETE SET NULL,
    INDEX idx_teacher (teacher_id),
    INDEX idx_active (is_active)
);

-- 代碼版本表
CREATE TABLE IF NOT EXISTS code_versions (
    id INT AUTO_INCREMENT PRIMARY KEY,
    room_id VARCHAR(50) NOT NULL,
    version INT NOT NULL,
    code TEXT,
    user_id INT,
    operation ENUM('manual', 'auto', 'import') DEFAULT 'manual',
    file_name VARCHAR(255) DEFAULT '未命名',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (room_id) REFERENCES rooms(id) ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL,
    UNIQUE KEY unique_room_version (room_id, version),
    INDEX idx_room_version (room_id, version)
);

-- 聊天記錄表
CREATE TABLE IF NOT EXISTS chat_messages (
    id INT AUTO_INCREMENT PRIMARY KEY,
    room_id VARCHAR(50) NOT NULL,
    user_id INT,
    username VARCHAR(50),
    message TEXT NOT NULL,
    message_type ENUM('user', 'system', 'ai') DEFAULT 'user',
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (room_id) REFERENCES rooms(id) ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL,
    INDEX idx_room_time (room_id, timestamp)
);

-- 房間成員表
CREATE TABLE IF NOT EXISTS room_members (
    room_id VARCHAR(50),
    user_id INT,
    joined_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    last_active TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_online BOOLEAN DEFAULT TRUE,
    PRIMARY KEY (room_id, user_id),
    FOREIGN KEY (room_id) REFERENCES rooms(id) ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);
```

### 索引優化策略
```sql
-- 性能優化索引
CREATE INDEX idx_code_versions_room_latest ON code_versions(room_id, version DESC);
CREATE INDEX idx_chat_messages_recent ON chat_messages(room_id, timestamp DESC);
CREATE INDEX idx_room_members_online ON room_members(room_id, is_online);
CREATE INDEX idx_users_active ON users(last_active DESC);
```

