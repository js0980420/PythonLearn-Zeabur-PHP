## 🛠️ 數據操作封裝

### 用戶管理操作
```javascript
class UserManager {
    async createUser(username, displayName, role = 'student') {
        if (dataManager.isCloudMode) {
            const query = `
                INSERT INTO users (username, display_name, role) 
                VALUES (?, ?, ?)
                ON DUPLICATE KEY UPDATE 
                display_name = VALUES(display_name),
                last_active = CURRENT_TIMESTAMP
            `;
            const [result] = await pool.execute(query, [username, displayName, role]);
            return result.insertId;
        } else {
            const userId = dataManager.localData.users.size + 1;
            dataManager.localData.users.set(userId, {
                id: userId,
                username,
                displayName,
                role,
                lastActive: new Date(),
                createdAt: new Date()
            });
            return userId;
        }
    }

    async updateUserActivity(userId) {
        if (dataManager.isCloudMode) {
            const query = 'UPDATE users SET last_active = CURRENT_TIMESTAMP WHERE id = ?';
            await pool.execute(query, [userId]);
        } else {
            const user = dataManager.localData.users.get(userId);
            if (user) {
                user.lastActive = new Date();
            }
        }
    }
}
```

### 房間管理操作
```javascript
class RoomManager {
    async createRoom(roomId, roomName, teacherId) {
        if (dataManager.isCloudMode) {
            const query = `
                INSERT INTO rooms (id, name, teacher_id) 
                VALUES (?, ?, ?)
                ON DUPLICATE KEY UPDATE 
                name = VALUES(name),
                last_activity = CURRENT_TIMESTAMP
            `;
            await pool.execute(query, [roomId, roomName, teacherId]);
        } else {
            dataManager.localData.rooms.set(roomId, {
                id: roomId,
                name: roomName,
                teacherId,
                maxUsers: 5,
                createdAt: new Date(),
                lastActivity: new Date(),
                isActive: true,
                members: new Set()
            });
        }
    }

    async getRoomInfo(roomId) {
        if (dataManager.isCloudMode) {
            const query = `
                SELECT r.*, u.username as teacher_name
                FROM rooms r
                LEFT JOIN users u ON r.teacher_id = u.id
                WHERE r.id = ?
            `;
            const [rows] = await pool.execute(query, [roomId]);
            return rows[0];
        } else {
            return dataManager.localData.rooms.get(roomId);
        }
    }
}
```

### 代碼版本管理
```javascript
class CodeVersionManager {
    async saveCode(roomId, code, userId, operation = 'manual', fileName = '未命名') {
        if (dataManager.isCloudMode) {
            // 獲取下一個版本號
            const versionQuery = `
                SELECT COALESCE(MAX(version), 0) + 1 as next_version 
                FROM code_versions 
                WHERE room_id = ?
            `;
            const [versionResult] = await pool.execute(versionQuery, [roomId]);
            const nextVersion = versionResult[0].next_version;

            // 保存新版本
            const insertQuery = `
                INSERT INTO code_versions (room_id, version, code, user_id, operation, file_name)
                VALUES (?, ?, ?, ?, ?, ?)
            `;
            await pool.execute(insertQuery, [roomId, nextVersion, code, userId, operation, fileName]);
            return nextVersion;
        } else {
            const roomVersions = dataManager.localData.codeVersions.get(roomId) || [];
            const nextVersion = roomVersions.length + 1;
            
            roomVersions.push({
                version: nextVersion,
                code,
                userId,
                operation,
                fileName,
                createdAt: new Date()
            });
            
            dataManager.localData.codeVersions.set(roomId, roomVersions);
            return nextVersion;
        }
    }

    async loadCode(roomId, version = null) {
        if (dataManager.isCloudMode) {
            let query;
            let params;
            
            if (version) {
                query = 'SELECT * FROM code_versions WHERE room_id = ? AND version = ?';
                params = [roomId, version];
            } else {
                query = `
                    SELECT * FROM code_versions 
                    WHERE room_id = ? 
                    ORDER BY version DESC 
                    LIMIT 1
                `;
                params = [roomId];
            }
            
            const [rows] = await pool.execute(query, params);
            return rows[0];
        } else {
            const roomVersions = dataManager.localData.codeVersions.get(roomId) || [];
            if (version) {
                return roomVersions.find(v => v.version === version);
            } else {
                return roomVersions[roomVersions.length - 1];
            }
        }
    }
}
```

