## 📊 規則檔案管理系統

### 規則檔案清單檢查
```powershell
# rules-integrity-check.ps1
function Test-RulesIntegrity {
    Write-Host "🔍 開始規則檔案完整性檢查..."
    
    # 定義必要的規則檔案
    $required_rules = @(
        'meta_rules.mdc',
        'cursor_rules.mdc',
        'AI_assistant_rules.mdc',
        'editor_rules.mdc',
        'teacher_rules.mdc',
        'debug_rules.mdc',
        'command_rules.mdc',
        'deployment_rules.mdc',
        'mysql_rules.mdc',
        'architecture_rules.mdc'
    )
    
    $missing_files = @()
    foreach ($file in $required_rules) {
        $file_path = ".cursor/rules/$file"
        if (-not (Test-Path $file_path)) {
            $missing_files += $file
            Write-Host "❌ 缺少規則檔案: $file" -ForegroundColor Red
        } else {
            # 檢查檔案標頭格式
            $content = Get-Content $file_path -First 10
            $has_header = $content | Where-Object { $_ -match "規則類型.*always" }
            $has_protection = $content | Where-Object { $_ -match "檔案保護.*禁止刪除" }
            
            if ($has_header -and $has_protection) {
                Write-Host "✅ 規則檔案完整: $file" -ForegroundColor Green
            } else {
                Write-Host "⚠️ 規則檔案格式異常: $file" -ForegroundColor Yellow
            }
        }
    }
    
    if ($missing_files.Count -eq 0) {
        Write-Host "🎉 所有規則檔案完整" -ForegroundColor Green
        return $true
    } else {
        Write-Host "❌ 發現 $($missing_files.Count) 個缺失檔案" -ForegroundColor Red
        return $false
    }
}
```

### 規則同步機制
```powershell
# 規則檔案同步工具
function Sync-RulesFiles {
    param([string]$SourcePath, [string]$TargetPath)
    
    Write-Host "🔄 開始同步規則檔案..."
    
    $source_files = Get-ChildItem "$SourcePath/*.mdc"
    foreach ($file in $source_files) {
        $target_file = "$TargetPath/$($file.Name)"
        
        if (Test-Path $target_file) {
            $source_hash = Get-FileHash $file.FullName
            $target_hash = Get-FileHash $target_file
            
            if ($source_hash.Hash -ne $target_hash.Hash) {
                Copy-Item $file.FullName $target_file -Force
                Write-Host "🔄 更新: $($file.Name)" -ForegroundColor Yellow
            } else {
                Write-Host "✅ 相同: $($file.Name)" -ForegroundColor Green
            }
        } else {
            Copy-Item $file.FullName $target_file
            Write-Host "➕ 新增: $($file.Name)" -ForegroundColor Blue
        }
    }
    
    Write-Host "🎉 規則檔案同步完成" -ForegroundColor Green
}
```

