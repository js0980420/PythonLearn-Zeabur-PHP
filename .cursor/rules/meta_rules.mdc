## 🔍 規則執行監控

### 規則違規檢測
```powershell
# 規則違規自動檢測
function Test-RuleCompliance {
    Write-Host "🕵️ 開始規則遵循性檢查..."
    
    $violations = @()
    
    # 檢查檔案架構規則
    $file_count = (git ls-files).Count
    if ($file_count -ne 15) {
        $violations += "檔案數量違規: $file_count (應為15)"
    }
    
    # 檢查禁止檔案
    $forbidden_files = git ls-files | Where-Object { $_ -match '\.(md|txt)$' }
    if ($forbidden_files) {
        $violations += "存在禁止檔案: $($forbidden_files -join ', ')"
    }
    
    # 檢查AI助教映射
    $ai_mappings = Select-String -Path "server.js" -Pattern "case 'analyze':"
    if (-not $ai_mappings) {
        $violations += "AI助教前後端映射不完整"
    }
    
    if ($violations.Count -eq 0) {
        Write-Host "✅ 所有規則遵循檢查通過" -ForegroundColor Green
    } else {
        Write-Host "❌ 發現 $($violations.Count) 項規則違規:" -ForegroundColor Red
        $violations | ForEach-Object { Write-Host "  - $_" -ForegroundColor Red }
    }
    
    return $violations.Count -eq 0
}
```

### 規則執行報告
```powershell
# 生成規則執行報告
function Generate-RuleReport {
    $report = @{
        timestamp = Get-Date
        file_count = (git ls-files).Count
        rules_integrity = Test-RulesIntegrity
        compliance = Test-RuleCompliance
        last_update = (Get-ChildItem ".cursor/rules/*.mdc" | Sort-Object LastWriteTime -Descending | Select-Object -First 1).LastWriteTime
    }
    
    $report_json = $report | ConvertTo-Json -Depth 3
    $report_json | Out-File ".cursor/compliance_report.json" -Encoding UTF8
    
    Write-Host "📊 規則執行報告已生成" -ForegroundColor Cyan
}
```

