## 🔧 函數設計規範

### 純函數設計
```javascript
// ✅ 純函數範例 - 無副作用，相同輸入產生相同輸出

/**
 * 驗證用戶輸入數據
 * @param {Object} userData - 用戶數據
 * @returns {Object} 驗證結果
 */
function validateUserData(userData) {
    const errors = [];
    
    if (!userData.name || userData.name.trim().length === 0) {
        errors.push('用戶名稱不能為空');
    }
    
    if (userData.name && userData.name.length > 30) {
        errors.push('用戶名稱不能超過30個字符');
    }
    
    if (!userData.roomName || userData.roomName.trim().length === 0) {
        errors.push('房間名稱不能為空');
    }
    
    return {
        isValid: errors.length === 0,
        errors: errors,
        userData: userData
    };
}

/**
 * 格式化聊天消息
 * @param {string} message - 原始消息
 * @param {string} userName - 用戶名稱
 * @param {number} timestamp - 時間戳
 * @returns {Object} 格式化後的消息對象
 */
function formatChatMessage(message, userName, timestamp = Date.now()) {
    return {
        id: generateMessageId(),
        content: message.trim(),
        author: userName,
        timestamp: timestamp,
        formattedTime: new Date(timestamp).toLocaleTimeString('zh-TW'),
        type: 'user'
    };
}

/**
 * 計算代碼差異
 * @param {string} oldCode - 舊代碼
 * @param {string} newCode - 新代碼
 * @returns {Object} 差異信息
 */
function calculateCodeDiff(oldCode, newCode) {
    const oldLines = oldCode.split('\n');
    const newLines = newCode.split('\n');
    
    const changes = {
        added: [],
        removed: [],
        modified: []
    };
    
    const maxLength = Math.max(oldLines.length, newLines.length);
    
    for (let i = 0; i < maxLength; i++) {
        const oldLine = oldLines[i];
        const newLine = newLines[i];
        
        if (oldLine === undefined) {
            changes.added.push({ line: i + 1, content: newLine });
        } else if (newLine === undefined) {
            changes.removed.push({ line: i + 1, content: oldLine });
        } else if (oldLine !== newLine) {
            changes.modified.push({ 
                line: i + 1, 
                oldContent: oldLine, 
                newContent: newLine 
            });
        }
    }
    
    return changes;
}
