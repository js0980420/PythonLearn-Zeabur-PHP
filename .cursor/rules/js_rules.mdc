## 🛡️ 錯誤處理規範

### 全域錯誤處理
```javascript
// ✅ 完整的錯誤處理策略

/**
 * 全域錯誤處理器
 */
class ErrorHandler {
    constructor() {
        this.setupGlobalHandlers();
        this.errorLog = [];
        this.maxLogEntries = 100;
    }
    
    /**
     * 設置全域錯誤監聽
     */
    setupGlobalHandlers() {
        // JavaScript 運行時錯誤
        window.addEventListener('error', (event) => {
            this.handleError({
                type: 'runtime',
                message: event.message,
                filename: event.filename,
                line: event.lineno,
                column: event.colno,
                error: event.error,
                timestamp: Date.now()
            });
        });
        
        // Promise 拒絕錯誤
        window.addEventListener('unhandledrejection', (event) => {
            this.handleError({
                type: 'promise',
                message: 'Unhandled Promise Rejection',
                reason: event.reason,
                timestamp: Date.now()
            });
        });
        
        // 資源載入錯誤
        window.addEventListener('error', (event) => {
            if (event.target !== window) {
                this.handleError({
                    type: 'resource',
                    message: 'Resource loading failed',
                    source: event.target.src || event.target.href,
                    element: event.target.tagName,
                    timestamp: Date.now()
                });
            }
        }, true);
    }
    
    /**
     * 處理錯誤
     * @param {Object} errorInfo - 錯誤信息
     */
    handleError(errorInfo) {
        // 記錄錯誤
        this.logError(errorInfo);
        
        // 顯示用戶友好的錯誤消息
        this.showUserError(errorInfo);
        
        // 發送錯誤報告到服務器
        this.reportError(errorInfo);
    }
    
    /**
     * 記錄錯誤到本地
     * @param {Object} errorInfo - 錯誤信息
     */
    logError(errorInfo) {
        this.errorLog.push(errorInfo);
        
        // 限制日誌大小
        if (this.errorLog.length > this.maxLogEntries) {
            this.errorLog = this.errorLog.slice(-this.maxLogEntries);
        }
        
        // 控制台輸出
        console.error('🚨 Error captured:', errorInfo);
    }
    
    /**
     * 顯示用戶錯誤提示
     * @param {Object} errorInfo - 錯誤信息
     */
    showUserError(errorInfo) {
        let userMessage = '';
        
        switch (errorInfo.type) {
            case 'runtime':
                userMessage = '程式運行發生錯誤，請重新載入頁面';
                break;
            case 'promise':
                userMessage = '操作失敗，請稍後再試';
                break;
            case 'resource':
                userMessage = '資源載入失敗，請檢查網路連接';
                break;
            default:
                userMessage = '發生未知錯誤，請聯繫技術支援';
        }
        
        if (window.UI && typeof window.UI.showErrorToast === 'function') {
            window.UI.showErrorToast(userMessage);
        } else {
            alert(userMessage);
        }
    }
    
    /**
     * 上報錯誤到服務器
     * @param {Object} errorInfo - 錯誤信息
     */
    async reportError(errorInfo) {
        try {
            const errorReport = {
                ...errorInfo,
                userAgent: navigator.userAgent,
                url: window.location.href,
                userId: window.currentUser || 'anonymous'
            };
            
            // 使用 fetch 發送錯誤報告
            await fetch('/api/error-report', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(errorReport)
            });
        } catch (error) {
            console.error('Failed to report error:', error);
        }
    }
    
    /**
     * 獲取錯誤統計
     * @returns {Object} 錯誤統計信息
     */
    getErrorStats() {
        const stats = {
            total: this.errorLog.length,
            byType: {},
            recent: this.errorLog.slice(-10)
        };
        
        this.errorLog.forEach(error => {
            stats.byType[error.type] = (stats.byType[error.type] || 0) + 1;
        });
        
        return stats;
    }
}

// 創建全域錯誤處理器
const errorHandler = new ErrorHandler();

/**
 * 安全執行函數 - 包裝可能出錯的代碼
 * @param {Function} fn - 要執行的函數
 * @param {string} context - 執行上下文描述
 * @param {*} fallbackValue - 錯誤時的回傳值
 * @returns {*} 執行結果或回傳值
 */
function safeExecute(fn, context = 'Unknown', fallbackValue = null) {
    try {
        return fn();
    } catch (error) {
        errorHandler.handleError({
            type: 'safe_execute',
            message: `Error in ${context}: ${error.message}`,
            context: context,
            error: error,
            timestamp: Date.now()
        });
        return fallbackValue;
    }
}

/**
 * 異步安全執行
 * @param {Function} asyncFn - 異步函數
 * @param {string} context - 執行上下文
 * @param {*} fallbackValue - 錯誤時的回傳值
 * @returns {Promise} 執行結果
 */
async function safeExecuteAsync(asyncFn, context = 'Unknown', fallbackValue = null) {
    try {
        return await asyncFn();
    } catch (error) {
        errorHandler.handleError({
            type: 'safe_execute_async',
            message: `Async error in ${context}: ${error.message}`,
            context: context,
            error: error,
            timestamp: Date.now()
        });
        return fallbackValue;
    }
}
