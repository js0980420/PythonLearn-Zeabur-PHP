```javascript
// ✅ 代碼品質檢查工具

/**
 * 代碼品質分析器
 */
class CodeQualityAnalyzer {
    /**
     * 檢查函數複雜度
     * @param {Function} func - 要檢查的函數
     * @returns {Object} 複雜度分析結果
     */
    static analyzeFunctionComplexity(func) {
        const funcString = func.toString();
        const lines = funcString.split('\n').length;
        const cyclomaticComplexity = this.calculateCyclomaticComplexity(funcString);
        
        return {
            lines,
            cyclomaticComplexity,
            recommendation: this.getComplexityRecommendation(cyclomaticComplexity)
        };
    }
    
    /**
     * 計算圈複雜度
     * @param {string} code - 代碼字符串
     * @returns {number} 圈複雜度
     */
    static calculateCyclomaticComplexity(code) {
        const patterns = [
            /\bif\b/g,
            /\belse\b/g,
            /\bwhile\b/g,
            /\bfor\b/g,
            /\bswitch\b/g,
            /\bcase\b/g,
            /\bcatch\b/g,
            /\?\s*\w+\s*:/g // 三元運算符
        ];
        
        let complexity = 1; // 基礎複雜度
        
        patterns.forEach(pattern => {
            const matches = code.match(pattern);
            if (matches) {
                complexity += matches.length;
            }
        });
        
        return complexity;
    }
    
    /**
     * 獲取複雜度建議
     * @param {number} complexity - 圈複雜度
     * @returns {string} 建議
     */
    static getComplexityRecommendation(complexity) {
        if (complexity <= 5) {
            return '複雜度良好，代碼清晰易懂';
        } else if (complexity <= 10) {
            return '複雜度適中，考慮重構以提高可讀性';
        } else if (complexity <= 15) {
            return '複雜度較高，建議拆分函數';
        } else {
            return '複雜度過高，強烈建議重構';
        }
    }
    
    /**
     * 檢查變數命名
     * @param {string} varName - 變數名稱
     * @returns {Object} 命名檢查結果
     */
    static checkVariableNaming(varName) {
        const checks = {
            isCamelCase: /^[a-z][a-zA-Z0-9]*$/.test(varName),
            isDescriptive: varName.length >= 3,
            hasNumbers: /\d/.test(varName),
            hasUnderscore: /_/.test(varName)
        };
        
        const suggestions = [];
        
        if (!checks.isCamelCase) {
            suggestions.push('使用駝峰式命名 (camelCase)');
        }
        
        if (!checks.isDescriptive) {
            suggestions.push('使用更具描述性的名稱');
        }
        
        if (checks.hasUnderscore && !varName.startsWith('_')) {
            suggestions.push('避免在變數名中使用下底線');
        }
        
        return {
            checks,
            isGood: checks.isCamelCase && checks.isDescriptive,
            suggestions
        };
    }
}

// 使用範例
function exampleFunction(data, options) {
    if (data && data.length > 0) {
        for (let item of data) {
            if (item.isValid) {
                processItem(item);
            } else {
                handleInvalidItem(item);
            }
        }
    }
}

const analysis = CodeQualityAnalyzer.analyzeFunctionComplexity(exampleFunction);
console.log('函數複雜度分析:', analysis);

const namingCheck = CodeQualityAnalyzer.checkVariableNaming('userName');
console.log('變數命名檢查:', namingCheck);
