## 🚀 性能優化技巧

### 防抖和節流
```javascript
// ✅ 性能優化工具函數

/**
 * 防抖函數 - 延遲執行，頻繁調用時重置計時器
 * @param {Function} func - 要防抖的函數
 * @param {number} wait - 等待時間（毫秒）
 * @param {boolean} immediate - 是否立即執行
 * @returns {Function} 防抖後的函數
 */
function debounce(func, wait, immediate = false) {
    let timeout;
    
    return function executedFunction(...args) {
        const later = () => {
            timeout = null;
            if (!immediate) func.apply(this, args);
        };
        
        const callNow = immediate && !timeout;
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
        
        if (callNow) func.apply(this, args);
    };
}

/**
 * 節流函數 - 限制執行頻率
 * @param {Function} func - 要節流的函數
 * @param {number} limit - 時間間隔（毫秒）
 * @returns {Function} 節流後的函數
 */
function throttle(func, limit) {
    let inThrottle;
    
    return function(...args) {
        if (!inThrottle) {
            func.apply(this, args);
            inThrottle = true;
            setTimeout(() => inThrottle = false, limit);
        }
    };
}

// 使用範例
const debouncedSave = debounce((code) => {
    console.log('Saving code:', code);
    // 保存邏輯
}, 500);

const throttledScroll = throttle(() => {
    console.log('Scroll event processed');
    // 滾動處理邏輯
}, 100);

// 編輯器內容變化處理
document.getElementById('code-editor').addEventListener('input', 
    debounce((event) => {
        handleCodeChange(event.target.value);
    }, 300)
);
```

### 內存管理
```javascript
// ✅ 內存管理最佳實踐

/**
 * 事件管理器 - 自動清理事件監聽器
 */
class EventManager {
    constructor() {
        this.listeners = new Set();
    }
    
    /**
     * 添加事件監聽器
     * @param {Element} element - DOM 元素
     * @param {string} event - 事件類型
     * @param {Function} handler - 事件處理函數
     * @param {Object} options - 事件選項
     */
    addEventListener(element, event, handler, options = {}) {
        element.addEventListener(event, handler, options);
        
        // 記錄監聽器以便後續清理
        this.listeners.add({
            element,
            event,
            handler,
            options
        });
    }
    
    /**
     * 移除特定事件監聽器
     * @param {Element} element - DOM 元素
     * @param {string} event - 事件類型
     * @param {Function} handler - 事件處理函數
     */
    removeEventListener(element, event, handler) {
        element.removeEventListener(event, handler);
        
        // 從記錄中移除
        for (const listener of this.listeners) {
            if (listener.element === element && 
                listener.event === event && 
                listener.handler === handler) {
                this.listeners.delete(listener);
                break;
            }
        }
    }
    
    /**
     * 清理所有事件監聽器
     */
    cleanup() {
        for (const listener of this.listeners) {
            listener.element.removeEventListener(
                listener.event, 
                listener.handler, 
                listener.options
            );
        }
        this.listeners.clear();
    }
}

/**
 * 資源池管理 - 重用物件減少 GC 壓力
 */
class ObjectPool {
    constructor(createFn, resetFn, initialSize = 10) {
        this.createFn = createFn;
        this.resetFn = resetFn;
        this.pool = [];
        
        // 預先創建物件
        for (let i = 0; i < initialSize; i++) {
            this.pool.push(this.createFn());
        }
    }
    
    /**
     * 獲取物件
     * @returns {Object} 池中的物件
     */
    acquire() {
        if (this.pool.length > 0) {
            return this.pool.pop();
        }
        return this.createFn();
    }
    
    /**
     * 釋放物件回池中
     * @param {Object} obj - 要釋放的物件
     */
    release(obj) {
        if (this.resetFn) {
            this.resetFn(obj);
        }
        this.pool.push(obj);
    }
    
    /**
     * 獲取池狀態
     * @returns {Object} 池統計信息
     */
    getStats() {
        return {
            available: this.pool.length,
            total: this.pool.length
        };
    }
}

// 聊天消息物件池
const messagePool = new ObjectPool(
    () => ({ id: null, content: '', author: '', timestamp: 0 }),
    (obj) => {
        obj.id = null;
        obj.content = '';
        obj.author = '';
        obj.timestamp = 0;
    }
);

// 使用範例
function createChatMessage(content, author) {
    const message = messagePool.acquire();
    message.id = generateId();
    message.content = content;
    message.author = author;
    message.timestamp = Date.now();
    return message;
}

function destroyChatMessage(message) {
    messagePool.release(message);
}
