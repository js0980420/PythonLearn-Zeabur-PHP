## 📊 檔案驗證腳本

### PowerShell 自動驗證
```powershell
# validate-before-upload.ps1
Write-Host "🔍 開始上傳前檢查..."

# 1. 測試本地服務器
$response = Invoke-WebRequest -Uri "http://localhost:8080" -TimeoutSec 10
if ($response.StatusCode -eq 200) {
    Write-Host "✅ 本地8080端口測試通過"
} else {
    Write-Host "❌ 本地服務器測試失敗"
    exit 1
}

# 2. 檢查檔案數量
$fileCount = (git ls-files).Count
if ($fileCount -eq 15) {
    Write-Host "✅ 檔案數量正確: $fileCount"
} else {
    Write-Host "❌ 檔案數量錯誤: $fileCount (應該是15)"
    exit 1
}

# 3. 檢查違規檔案
$violations = git ls-files | Where-Object { 
    $_ -match "node_modules|說明文件|\.md$" -and $_ -notmatch "package|zeabur"
}
if ($violations.Count -eq 0) {
    Write-Host "✅ 無違規檔案"
} else {
    Write-Host "❌ 發現違規檔案:"
    $violations | ForEach-Object { Write-Host "  - $_" }
    exit 1
}

Write-Host "✅ 所有檢查通過，可以安全上傳"
```

