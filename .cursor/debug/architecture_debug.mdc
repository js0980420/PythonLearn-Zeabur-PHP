  ```javascript
  // 開發環境路徑檢查工具
  class DevelopmentPathChecker {
      static async checkAllPaths() {
          const htmlFiles = ['index.html', 'teacher-dashboard.html', 'config.html'];
          const issues = [];
          
          for (const htmlFile of htmlFiles) {
              const response = await fetch(htmlFile);
              const html = await response.text();
              
              // 提取所有資源路徑
              const scriptPaths = this.extractScriptPaths(html);
              const stylePaths = this.extractStylePaths(html);
              
              // 驗證路徑
              for (const path of [...scriptPaths, ...stylePaths]) {
                  const isValid = await PathResolver.validatePath(path);
                  if (!isValid) {
                      issues.push({ file: htmlFile, path: path, type: 'missing' });
                  }
              }
          }
          
          if (issues.length > 0) {
              console.error('❌ 發現路徑問題:', issues);
          } else {
              console.log('✅ 所有路徑檢查通過');
          }
          
          return issues;
      }
  }
  ```

