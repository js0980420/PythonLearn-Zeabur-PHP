  2. **模組依賴管理**:
     ```javascript
     // public/js/editor.js 依賴管理
     class EditorManager {
         constructor() {
             // 檢查必要的全域物件
             this.validateDependencies();
             
             // 初始化編輯器
             this.initializeEditor();
         }
         
         validateDependencies() {
             const requiredGlobals = ['wsManager', 'UI', 'chatManager'];
             const missing = requiredGlobals.filter(global => !window[global]);
             
             if (missing.length > 0) {
                 console.error(`❌ 缺少必要依賴: ${missing.join(', ')}`);
                 throw new Error(`依賴檢查失敗: ${missing.join(', ')}`);
             }
             
             console.log('✅ 編輯器依賴檢查通過');
         }
     }
     
     // 全域註冊
     window.editorManager = new EditorManager();
     ```

  3. **路徑解析工具**:
     ```javascript
     // public/js/ui.js 路徑工具
     class PathResolver {
         static getBasePath() {
             const scripts = document.getElementsByTagName('script');
             const currentScript = scripts[scripts.length - 1];
             const scriptPath = currentScript.src;
             
             // 提取base path
             const pathParts = scriptPath.split('/');
             pathParts.pop(); // 移除檔案名
             return pathParts.join('/');
         }
         
         static resolveAssetPath(relativePath) {
             const basePath = window.location.origin;
             return `${basePath}/${relativePath}`;
         }
         
         static validatePath(path) {
             return fetch(path, { method: 'HEAD' })
                 .then(response => response.ok)
                 .catch(() => false);
         }
     }
     
     // 全域路徑工具
     window.PathResolver = PathResolver;
     ```

  4. **載入順序驗證**:
     ```javascript
     // 模組載入順序檢查
     class ModuleLoadMonitor {
         constructor() {
             this.loadedModules = [];
             this.requiredOrder = [
                 'websocket.js',
                 'ui.js', 
                 'chat.js',
                 'conflict.js',
                 'ai-assistant.js',
                 'editor.js'
             ];
         }
         
         registerModule(moduleName) {
             this.loadedModules.push(moduleName);
             console.log(`📦 模組已載入: ${moduleName}`);
             
             this.validateLoadOrder();
         }
         
         validateLoadOrder() {
             const currentIndex = this.loadedModules.length - 1;
             const expectedModule = this.requiredOrder[currentIndex];
             const actualModule = this.loadedModules[currentIndex];
             
             if (actualModule !== expectedModule) {
                 console.warn(`⚠️ 模組載入順序警告: 期望 ${expectedModule}, 實際 ${actualModule}`);
             }
             
             if (this.loadedModules.length === this.requiredOrder.length) {
                 console.log('✅ 所有模組載入完成，順序正確');
             }
         }
     }
     
     // 全域載入監控
     window.moduleLoadMonitor = new ModuleLoadMonitor();
     ```

