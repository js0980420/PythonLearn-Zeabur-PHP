             this.messageCount++;
             this.metrics.averageProcessingTime = 
                 (this.metrics.averageProcessingTime + processingTime) / 2;
         }
         
         resetCounters() {
             this.metrics.messagesPerSecond = this.messageCount;
             this.messageCount = 0;
         }
         
         reportMetrics() {
             this.metrics.memoryUsage = process.memoryUsage().heapUsed / 1024 / 1024;
             this.metrics.connectionCount = totalWebSocketConnections;
             
             console.log(`📊 WebSocket性能指標:`, {
                 'Messages/sec': this.metrics.messagesPerSecond,
                 'Avg Processing': `${this.metrics.averageProcessingTime.toFixed(2)}ms`,
                 'Queue Length': this.metrics.queueLength,
                 'Connections': this.metrics.connectionCount,
                 'Memory': `${this.metrics.memoryUsage.toFixed(2)}MB`
             });
             
             // 性能警告
             if (this.metrics.messagesPerSecond > 1000) {
                 console.warn('⚠️ 高消息頻率警告');
             }
             
             if (this.metrics.averageProcessingTime > 50) {
                 console.warn('⚠️ 處理延遲過高警告');
             }
         }
     }
     ```

