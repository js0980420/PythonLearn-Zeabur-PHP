  ```javascript
  // 同步品質監控
  class SyncMonitor {
      constructor() {
          this.syncMetrics = {
              totalSyncs: 0,
              successfulSyncs: 0,
              conflicts: 0,
              averageSyncTime: 0
          };
      }
      
      recordSync(syncTime, success, hasConflict) {
          this.syncMetrics.totalSyncs++;
          if (success) this.syncMetrics.successfulSyncs++;
          if (hasConflict) this.syncMetrics.conflicts++;
          
          this.syncMetrics.averageSyncTime = 
              (this.syncMetrics.averageSyncTime + syncTime) / 2;
      }
      
      getSuccessRate() {
          return (this.syncMetrics.successfulSyncs / this.syncMetrics.totalSyncs * 100).toFixed(2);
      }
  }
  ```

